# Example NAS mounts — edit for your NAS, then merge into /etc/fstab
# Test first: sudo mount -a
#
# SMB (Synology/QNAP/Windows share):
# //192.168.1.50/media    /mnt/nas/media    cifs  credentials=/etc/nas-credentials,uid=1000,gid=1000,file_mode=0664,dir_mode=0775,nofail,_netdev,x-systemd.automount  0  0
# //192.168.1.50/downloads /mnt/nas/downloads cifs  credentials=/etc/nas-credentials,uid=1000,gid=1000,file_mode=0664,dir_mode=0775,nofail,_netdev,x-systemd.automount  0  0
# //192.168.1.50/appdata  /mnt/nas/appdata  cifs  credentials=/etc/nas-credentials,uid=1000,gid=1000,file_mode=0664,dir_mode=0775,nofail,_netdev,x-systemd.automount  0  0
#
# NFS:
# 192.168.1.50:/volume1/media      /mnt/nas/media      nfs  rw,nofail,_netdev,x-systemd.automount  0  0
# 192.168.1.50:/volume1/downloads  /mnt/nas/downloads  nfs  rw,nofail,_netdev,x-systemd.automount  0  0
# 192.168.1.50:/volume1/appdata    /mnt/nas/appdata    nfs  rw,nofail,_netdev,x-systemd.automount  0  0
