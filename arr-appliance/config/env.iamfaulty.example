# Petee / iamfaulty homelab — copy to /opt/arr-appliance/.env
# Source: iamfaulty-homelab README

PUID=1000
PGID=1000
TZ=America/Denver

# NAS1 (2-bay NAS) — single SMB share "homelab"
NAS_ROOT=/mnt/nas
NAS_APPDATA=/mnt/nas/personal/arr-appliance
NAS_DOWNLOADS=/mnt/nas/media/downloads
NAS_MEDIA=/mnt/nas/media

# Match existing Jellyfin library layout on the NAS
NAS_TV=/mnt/nas/media/Shows
NAS_MOVIES=/mnt/nas/media/Movies

LOCAL_DISK_MAX_PCT=85
