# Synology DS223J — backup mount over Tailscale (internet-connected NAS)
# Use the Synology Tailscale IP — NOT a public IP, NOT port-forwarded SMB.
# Get IP from: Tailscale admin console, or DSM Tailscale package.
#
# Primary *arr/media stays on NAS1 (home LAN) — fstab.iamfaulty.example
#
# sudo nano /etc/nas-credentials-synology
#   username=peteedoo
#   password=YOUR_SYNOLOGY_PASSWORD
# sudo chmod 600 /etc/nas-credentials-synology
# sudo mkdir -p /mnt/synology
#
# Install Tailscale on Linux host first, join same tailnet as the Synology.
#
# Test (replace 100.x.y.z):
#   tailscale ping 100.x.y.z
#   sudo mount -t cifs -o credentials=/etc/nas-credentials-synology,uid=1000,gid=1000,vers=3.0 //100.x.y.z/backup /mnt/synology

//100.x.y.z/backup  /mnt/synology  cifs  credentials=/etc/nas-credentials-synology,uid=1000,gid=1000,file_mode=0664,dir_mode=0775,vers=3.0,nofail,_netdev,x-systemd.automount  0  0

# If the Synology is later on home LAN too, you may add a second fstab line
# with 192.168.1.51 — use only one active mount path to avoid duplicates.
#
# SFTP/rsync alternative (often nicer over internet):
#   rsync -av -e ssh /source/ peteedoo@100.x.y.z:/volume1/backup/homelab-mirror/
