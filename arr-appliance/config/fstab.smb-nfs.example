# 2-bay NAS — merge into /etc/fstab
# Replace 192.168.1.50 with your NAS IP (NAS app or router DHCP list).
#
# On the NAS first:
#   Control Panel → File Service → SMB → Enable
#   File Manager → create shared folders (names below are suggestions):
#     media, downloads, appdata
#   Give your NAS user read/write on all three.
#
# On the Mac Mini:
#   sudo nano /etc/nas-credentials
#     username=YOUR_NAS_USER
#     password=YOUR_NAS_PASSWORD
#   sudo chmod 600 /etc/nas-credentials
#   sudo mkdir -p /mnt/nas/{media,downloads,appdata}
#
# Test one mount before adding all lines:
#   sudo mount -t cifs -o credentials=/etc/nas-credentials,uid=1000,gid=1000 //192.168.1.50/media /mnt/nas/media

//192.168.1.50/media      /mnt/nas/media      cifs  credentials=/etc/nas-credentials,uid=1000,gid=1000,file_mode=0664,dir_mode=0775,vers=3.0,nofail,_netdev,x-systemd.automount  0  0
//192.168.1.50/downloads  /mnt/nas/downloads  cifs  credentials=/etc/nas-credentials,uid=1000,gid=1000,file_mode=0664,dir_mode=0775,vers=3.0,nofail,_netdev,x-systemd.automount  0  0
//192.168.1.50/appdata    /mnt/nas/appdata    cifs  credentials=/etc/nas-credentials,uid=1000,gid=1000,file_mode=0664,dir_mode=0775,vers=3.0,nofail,_netdev,x-systemd.automount  0  0

# ── NFS alternative (faster on Linux; IP allowlist on NAS) ───────────────────
# Control Panel → File Service → NFS → Enable
# Per folder: Properties → NFS → Add rule:
#   Client IP = Mac Mini LAN IP, RW, squash = map all users to admin
#
# 192.168.1.50:/volume1/media      /mnt/nas/media      nfs  rw,nfsvers=4,nofail,_netdev,x-systemd.automount  0  0
# 192.168.1.50:/volume1/downloads  /mnt/nas/downloads  nfs  rw,nfsvers=4,nofail,_netdev,x-systemd.automount  0  0
# 192.168.1.50:/volume1/appdata    /mnt/nas/appdata    nfs  rw,nfsvers=4,nofail,_netdev,x-systemd.automount  0  0
