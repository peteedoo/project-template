# Copy to .env and edit: cp .env.example .env

# Your user (id; whoami) — usually 1000 on Ubuntu
PUID=1000
PGID=1000
TZ=America/Denver

# NAS mount root — everything heavy lives here
NAS_ROOT=/mnt/nas

NAS_APPDATA=/mnt/nas/appdata
NAS_DOWNLOADS=/mnt/nas/downloads
NAS_MEDIA=/mnt/nas/media

# Stop containers if local disk fills past this percent (cripple itself, not your main Mac)
LOCAL_DISK_MAX_PCT=85
